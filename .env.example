# ── PostgreSQL (docker-compose 및 백엔드 공용) ──
POSTGRES_DB=open_forms
POSTGRES_USER=open_forms
POSTGRES_PASSWORD=open_forms
POSTGRES_PORT=5432

# ── 백엔드 (Spring Boot) ──
# JDBC URL은 위 값과 일치해야 함
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/open_forms
SPRING_DATASOURCE_USERNAME=open_forms
SPRING_DATASOURCE_PASSWORD=open_forms

# JWT (반드시 운영에서는 안전한 랜덤 값으로 교체할 것, 최소 32바이트)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION_SECONDS=3600

# 리프레시 토큰 유효 기간(일). 액세스 토큰이 만료돼도 이 기간 동안은 재로그인 없이 갱신됩니다.
REFRESH_TOKEN_EXPIRATION_DAYS=14

# ── 데모 시드 데이터 ──
# 첫 기동 시 데모 계정 3개·설문 18개·응답 227건이 자동으로 들어갑니다(demo1~3@openforms.dev / demo1234!).
# 빈 DB 로 시작하려면 아래 주석을 해제하십시오. 이미 시드가 들어간 DB 라면 `docker compose down -v` 로
# 초기화한 뒤 실행해야 합니다(적용된 마이그레이션이 사라지면 Flyway 검증에 걸립니다).
# spring.flyway.locations=classpath:db/migration

# ── 프론트엔드 (Vite) ──
# 프론트는 이 파일이 아니라 open_forms_frontend/.env 를 읽습니다(Vite 는 프로젝트 디렉터리 기준).
# 기본값 `/api` + 개발 서버 프록시로 동작하므로 보통 설정할 필요가 없습니다.
# 자세한 내용은 open_forms_frontend/.env.example 참고.

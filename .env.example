# ── PostgreSQL (docker-compose 및 백엔드 공용) ──
POSTGRES_DB=open_forms
POSTGRES_USER=open_forms
POSTGRES_PASSWORD=open_forms
POSTGRES_PORT=5432

# ── 백엔드 (Spring Boot) ──
# JDBC URL은 위 값과 일치해야 함
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/open_forms
SPRING_DATASOURCE_USERNAME=open_forms
SPRING_DATASOURCE_PASSWORD=open_forms

# JWT (반드시 운영에서는 안전한 랜덤 값으로 교체할 것, 최소 32바이트)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION_SECONDS=3600

# ── 프론트엔드 (Vite) ──
VITE_API_BASE_URL=http://localhost:8080
